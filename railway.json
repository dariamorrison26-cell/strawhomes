{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --frozen-lockfile && npm run build"
  },
  "deploy": {
    "startCommand": "npx serve dist -l $PORT --no-clipboard",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}